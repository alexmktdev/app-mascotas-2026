# ─────────────────────────────────────────────────────────────────────────
# Firebase Auth (cliente — solo Auth, expuesto al navegador)
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK (servidor — Firestore + Auth admin)
# Generar en: Firebase Console → Project Settings → Service Accounts →
# Generate new private key. FIREBASE_PRIVATE_KEY debe incluir los \n
# literales (entre comillas) o el salto de línea real.
# ─────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Nombre de la cookie de sesión y duración (segundos). Opcional.
SESSION_COOKIE_NAME=session
SESSION_COOKIE_MAX_AGE=432000

# ─────────────────────────────────────────────────────────────────────────
# Cloudflare R2 (servidor — almacenamiento de fotos de mascotas)
# ─────────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# URL pública del bucket (dominio público de R2.dev o dominio custom)
R2_PUBLIC_URL=
# Hostname usado por next/image para optimizar imágenes servidas desde R2
R2_PUBLIC_HOSTNAME=
