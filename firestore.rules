rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════
    // DENY ALL — El acceso a Firestore es exclusivamente vía Firebase Admin
    // SDK desde el servidor de Next.js (Server Components, Route Handlers y
    // Server Actions). El cliente web ya no usa firebase/firestore.
    //
    // El Admin SDK bypassa estas reglas; se mantienen como documentación y
    // como defensa en profundidad ante una eventual exposición accidental
    // de credenciales del cliente.
    // ═══════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
